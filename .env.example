# Replace both values before deploying outside local development.
DASHBOARD_AUTH_TOKEN=replace-with-generated-viewer-token
DASHBOARD_DEVELOPER_AUTH_TOKEN=replace-with-generated-developer-token

REDIS_URL=redis://redis:6379/0
DASHBOARD_REDIS_CHANNEL=agent:traces
DASHBOARD_REPLAY_BUFFER_SIZE=50
DASHBOARD_CORS_ORIGINS=http://localhost:8090
DASHBOARD_CONFIG_PATH=dashboard_service/config/default.dashboard.json
DASHBOARD_ENABLE_REDIS_SUBSCRIBER=true
DASHBOARD_TRACE_INCLUDE_DETAIL=false
